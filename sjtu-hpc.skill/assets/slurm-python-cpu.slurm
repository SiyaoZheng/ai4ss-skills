#!/bin/bash
#===============================================================================
# SJTU HPC Slurm Template: Python CPU Job
# 适用场景: 数据清洗、统计分析、机器学习（非深度学习）、文本处理
#===============================================================================

#-------------------------------------------------------------------------------
# 作业基本信息
#-------------------------------------------------------------------------------
#SBATCH --job-name=python_job           # 作业名称（建议用项目名简称）
#SBATCH --partition=small               # 队列选择:
                                        #   small: 1-20核, 适合小型任务
                                        #   cpu: 40-24000核, 中大型任务
                                        #   64c512g: 思源一号, 大内存任务

#-------------------------------------------------------------------------------
# 资源配置
#-------------------------------------------------------------------------------
#SBATCH -n 4                            # 总核数（CPU数）
#SBATCH --ntasks-per-node=4             # 每节点使用的核数
#SBATCH --mem=16G                       # 内存申请（建议：每核4G起步）
#SBATCH --time=24:00:00                 # 最大运行时间 (HH:MM:SS)

#-------------------------------------------------------------------------------
# 输出与通知
#-------------------------------------------------------------------------------
#SBATCH --output=%j.out                 # 标准输出文件 (%j=作业ID)
#SBATCH --error=%j.err                  # 错误输出文件
#SBATCH --mail-type=END,FAIL            # 邮件通知: 结束或失败时
#SBATCH --mail-user=YOUR_EMAIL@sjtu.edu.cn

#===============================================================================
# 环境配置
#===============================================================================

# 加载 Python 环境
module purge                            # 清除已加载模块，避免冲突
module load miniconda3

# 激活 conda 环境（替换为你的环境名）
source activate your_env_name

# 显示环境信息（便于调试）
echo "=========================================="
echo "Job ID: $SLURM_JOB_ID"
echo "Node: $SLURM_NODELIST"
echo "Cores: $SLURM_NTASKS"
echo "Working directory: $(pwd)"
echo "Python: $(which python)"
echo "Start time: $(date)"
echo "=========================================="

#===============================================================================
# 运行程序
#===============================================================================

# 单脚本运行
python your_script.py

# 或者带参数运行
# python your_script.py --input data.csv --output results.csv --cores $SLURM_NTASKS

#===============================================================================
# 结束信息
#===============================================================================
echo "=========================================="
echo "End time: $(date)"
echo "Job finished"
echo "=========================================="

#===============================================================================
# 使用说明
#===============================================================================
# 提交作业: sbatch slurm-python-cpu.slurm
# 查看队列: squeue -u $USER
# 取消作业: scancel <job_id>
# 查看作业详情: sacct -j <job_id> --format=JobID,JobName,MaxRSS,Elapsed
#
# 内存估算建议（计算社会科学常见场景）:
#   - 数据清洗 (pandas): 数据文件大小 × 3-5
#   - 文本分析 (sklearn): 语料库大小 × 5-10
#   - 网络分析 (networkx): 节点数^2 × 8 bytes (稀疏图可减少)
#===============================================================================
