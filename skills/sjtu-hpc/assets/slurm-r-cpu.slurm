#!/bin/bash
#===============================================================================
# SJTU HPC Slurm Template: R CPU Job
# 适用场景: 统计建模、回归分析、因果推断、面板数据分析
#===============================================================================

#-------------------------------------------------------------------------------
# 作业基本信息
#-------------------------------------------------------------------------------
#SBATCH --job-name=r_job                # 作业名称
#SBATCH --partition=small               # 队列选择:
                                        #   small: 1-20核, 单机统计分析
                                        #   cpu: 40核以上, 大规模计算
                                        #   64c512g: 思源一号, 超大数据集

#-------------------------------------------------------------------------------
# 资源配置
#-------------------------------------------------------------------------------
#SBATCH -n 4                            # CPU核数
#SBATCH --ntasks-per-node=4
#SBATCH --mem=32G                       # 内存（R通常需要较多内存）
#SBATCH --time=48:00:00                 # 最大运行时间

#-------------------------------------------------------------------------------
# 输出与通知
#-------------------------------------------------------------------------------
#SBATCH --output=%j.out
#SBATCH --error=%j.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=YOUR_EMAIL@sjtu.edu.cn

#===============================================================================
# 环境配置
#===============================================================================

module purge
module load r/4.2.0                     # 加载R (查看可用版本: module avail r)

# 如果使用 conda 管理的 R
# module load miniconda3
# source activate r_env

# 设置 R 库路径（如有自定义库）
# export R_LIBS_USER=~/R/library

# 设置线程数（用于支持多线程的R包）
export OMP_NUM_THREADS=$SLURM_NTASKS
export MKL_NUM_THREADS=$SLURM_NTASKS

# 显示环境信息
echo "=========================================="
echo "Job ID: $SLURM_JOB_ID"
echo "Node: $SLURM_NODELIST"
echo "Cores: $SLURM_NTASKS"
echo "R version: $(R --version | head -1)"
echo "Start time: $(date)"
echo "=========================================="

#===============================================================================
# 运行程序
#===============================================================================

# 运行 R 脚本
Rscript your_analysis.R

# 或者带参数运行
# Rscript your_analysis.R --input data.csv --output results.rds

# 传递 Slurm 环境变量到 R
# Rscript your_analysis.R --cores $SLURM_NTASKS

#===============================================================================
# 结束信息
#===============================================================================
echo "=========================================="
echo "End time: $(date)"
echo "Job finished"
echo "=========================================="

#===============================================================================
# 使用说明
#===============================================================================
# 提交作业: sbatch slurm-r-cpu.slurm
# 查看队列: squeue -u $USER
#
# 内存估算（计算社会科学常见场景）:
#   - 线性回归 (lm): 数据大小 × 3-5
#   - 面板数据 (plm/fixest): 数据大小 × 5-10
#   - 多层模型 (lme4): 数据大小 × 10-20
#   - 结构方程 (lavaan): 数据大小 × 5-10
#   - MICE多重插补: 数据大小 × m × 3 (m=插补次数)
#
# R脚本中获取核数:
#   cores <- as.integer(Sys.getenv("SLURM_NTASKS", "1"))
#
# 支持多线程的常用R包:
#   - data.table: 自动使用多线程
#   - fixest: 并行计算固定效应
#   - ranger: 并行随机森林
#   - xgboost: 多线程梯度提升
#===============================================================================
