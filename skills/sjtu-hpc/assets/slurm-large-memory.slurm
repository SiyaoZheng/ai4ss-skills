#!/bin/bash
#===============================================================================
# SJTU HPC Slurm Template: Large Memory Job
# 适用场景: 大规模网络分析、全国普查数据、大型稀疏矩阵、内存密集型计算
#===============================================================================

#-------------------------------------------------------------------------------
# 作业基本信息
#-------------------------------------------------------------------------------
#SBATCH --job-name=large_mem            # 作业名称
#SBATCH --partition=huge                # 大内存队列选择:
                                        #   huge: 最大 3TB 内存
                                        #   192c6t: 192核 6TB 内存 (超大任务)
                                        #   64c512g: 思源一号 512GB (较常用)

#-------------------------------------------------------------------------------
# 资源配置（大内存任务）
#-------------------------------------------------------------------------------
#SBATCH -n 16                           # CPU核数（根据实际需要）
#SBATCH --ntasks-per-node=16
#SBATCH --mem=500G                      # 大内存申请 (根据数据量调整)
                                        # huge队列: 最大 3000G
                                        # 192c6t队列: 最大 6000G
#SBATCH --time=168:00:00                # 最大运行时间 (大任务可能需要更长)

#-------------------------------------------------------------------------------
# 输出与通知
#-------------------------------------------------------------------------------
#SBATCH --output=%j.out
#SBATCH --error=%j.err
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=YOUR_EMAIL@sjtu.edu.cn

#===============================================================================
# 环境配置
#===============================================================================

module purge
module load miniconda3
source activate your_env_name

# 或加载 R
# module load r/4.2.0

# 设置线程数
export OMP_NUM_THREADS=$SLURM_NTASKS
export MKL_NUM_THREADS=$SLURM_NTASKS

# 增加 Python/R 的内存限制（如果需要）
# ulimit -v unlimited  # 虚拟内存不限制

echo "=========================================="
echo "Job ID: $SLURM_JOB_ID"
echo "Node: $SLURM_NODELIST"
echo "Cores: $SLURM_NTASKS"
echo "Memory requested: $SLURM_MEM_PER_NODE MB"
echo "Start time: $(date)"
echo "=========================================="

# 显示可用内存
free -h
echo "=========================================="

#===============================================================================
# 运行程序
#===============================================================================

# Python 大内存任务
python large_scale_analysis.py

# R 大内存任务
# Rscript large_data_analysis.R

#===============================================================================
# 结束信息
#===============================================================================
echo "=========================================="
echo "End time: $(date)"
echo "Final memory usage:"
free -h
echo "Job finished"
echo "=========================================="

#===============================================================================
# 内存估算指南
#===============================================================================
#
# 【数据读取内存估算】
# CSV 文件 (pandas): 文件大小 × 3-5
# Parquet 文件: 文件大小 × 1.5-2
# RDS 文件 (R): 文件大小 × 2-3
#
# 【常见分析任务】
# 大规模回归 (1亿行):
#   - 数据: ~100GB
#   - 计算: ~50GB
#   - 总计: 建议申请 200-300GB
#
# 社会网络分析:
#   - 邻接矩阵: N × N × 8 bytes (double)
#   - 100万节点: 约 8TB (需要稀疏矩阵!)
#   - 稀疏矩阵: 边数 × 24 bytes (粗略)
#   - 10亿边网络: 约 24GB + 元数据
#
# 文本分析 (TF-IDF/DTM):
#   - 文档数 × 词汇量 × 8 bytes (密集)
#   - 100万文档 × 10万词: 800GB (密集)
#   - 稀疏矩阵: 大幅减少，取决于稀疏度
#
# 人口普查微观数据:
#   - 中国人口普查: ~100GB (全样本)
#   - 美国ACS: ~20GB (年度)
#   - 建议: 申请数据大小 × 3
#
#===============================================================================
# 内存优化技巧
#===============================================================================
#
# 【Python】
# 1. 使用 chunked 读取:
#    for chunk in pd.read_csv('huge.csv', chunksize=100000):
#        process(chunk)
#
# 2. 优化数据类型:
#    df['id'] = df['id'].astype('int32')  # 减半内存
#    df['category'] = df['category'].astype('category')
#
# 3. 使用 Dask 处理超大数据:
#    import dask.dataframe as dd
#    ddf = dd.read_parquet('huge_data/*.parquet')
#
# 4. 稀疏矩阵:
#    from scipy.sparse import csr_matrix
#    sparse_mat = csr_matrix(dense_mat)
#
# 【R】
# 1. 使用 data.table 替代 data.frame:
#    library(data.table)
#    dt <- fread('huge.csv')
#
# 2. 分块读取:
#    library(readr)
#    read_csv_chunked('huge.csv', callback = function(chunk, pos) {...})
#
# 3. Arrow/Parquet 格式:
#    library(arrow)
#    df <- read_parquet('data.parquet')
#
# 4. 稀疏矩阵:
#    library(Matrix)
#    sparse_mat <- as(dense_mat, "sparseMatrix")
#
# 5. 磁盘缓存大对象:
#    library(fst)
#    write_fst(df, 'temp.fst')
#    df <- read_fst('temp.fst')
#
#===============================================================================
# 队列选择建议
#===============================================================================
#
# 内存需求        推荐队列        说明
# ----------------------------------------------------------------
# < 200GB        64c512g        思源一号，排队时间短
# 200GB-500GB    64c512g/huge   优先尝试64c512g
# 500GB-3TB     huge           标准大内存队列
# > 3TB          192c6t         超大内存，需要特殊审批
#
# 注意: 大内存队列节点较少，排队时间可能较长
# 建议: 先用小数据测试，确认内存需求后再提交大任务
#
#===============================================================================
