  quote_hash: "sha256:7a243819102ea4d452851fb7c16830bd70692f6157a0a36643a63ecda0648a97"
}

attribute demo.green_patenting {
  domain: ordinal
  values: ["low", "high"]
  description: "observed green patenting intensity in a firm-year"
  source: "literature_matrix row smith_2024_city_ai"
  spans: [demo.span_green_patenting]
}

// ---- Concepts ----

span demo.span_exposed_unit {
  source: demo.src_evidence
  locator: "Concepts/demo.exposed_unit"
  quote_hash: "sha256:7a243819102ea4d452851fb7c16830bd70692f6157a0a36643a63ecda0648a97"
}

concept demo.exposed_unit {
  term: "exposed unit"
  definition: "firm-year observation exposed to platform rollout"
  spans: [demo.span_exposed_unit]
  parents: ["demo.platform_exposure"]
  theta: {
    "[\"unexposed\"]": 0
    "[\"exposed\"]": 1
  }
  rule: definitional
  description: "firm-year observation exposed to platform rollout"
  source: "literature_matrix row smith_2024_city_ai"
  operationalization: "city-year rollout status linked to firm-year panel"
}

span demo.span_high_innovation {
  source: demo.src_evidence
  locator: "Concepts/demo.high_innovation"
  quote_hash: "sha256:7a243819102ea4d452851fb7c16830bd70692f6157a0a36643a63ecda0648a97"
}

concept demo.high_innovation {
  term: "high innovation"
  definition: "high green patenting relative to the analysis scale"
  spans: [demo.span_high_innovation]
  parents: ["demo.green_patenting"]
  theta: {
    "[\"low\"]": 0
    "[\"high\"]": 1
  }
  rule: threshold
  description: "high green patenting relative to the analysis scale"
  source: "literature_matrix row smith_2024_city_ai"
  operationalization: "green patent count by firm-year"
}

// ---- Causal Relations ----

