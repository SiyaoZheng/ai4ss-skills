#!/usr/bin/env python3
"""Command-line entrypoint for the AI4SS manuscript reviewer."""

from __future__ import annotations

import argparse
import contextlib
import io
import json
import os
import shutil
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any


SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

import parse_dp16276_checklist  # noqa: E402
import run_review_state  # noqa: E402


DEFAULT_MODEL = "claude-fable-5"
DEFAULT_PROVIDER = "openai"
DEFAULT_BASE_URL = "https://www.packyapi.com/v1"
DEFAULT_API_FORMAT = "chat"
DEFAULT_API_KEY_ENV = "PACKYCODE_CODEX_KEY"
DEFAULT_SCORER_MODE = "item"
DEFAULT_BACKEND = "cli"
DEFAULT_CHECKLIST_JSON = SCRIPT_DIR.parent / "assets" / "checklists" / "dp16276-tdd-checklist.json"


def configured_api_key_env() -> str:
    return os.environ.get("MANUSCRIPT_REVIEWER_API_KEY_ENV") or DEFAULT_API_KEY_ENV


def has_flag(argv: list[str], flag: str) -> bool:
    return any(arg == flag or arg.startswith(f"{flag}=") for arg in argv)


def without_flag(argv: list[str], flag: str) -> list[str]:
    cleaned: list[str] = []
    skip_next = False
    for arg in argv:
        if skip_next:
            skip_next = False
            continue
        if arg == flag:
            skip_next = True
            continue
        if arg.startswith(f"{flag}="):
            continue
        cleaned.append(arg)
    return cleaned


def add_default(argv: list[str], flag: str, value: str) -> list[str]:
    if has_flag(argv, flag):
        return argv
    return [flag, value, *argv]


def review(argv: list[str]) -> int:
    forwarded = list(argv)
    scaffold = "--scaffold" in forwarded
    forwarded = [arg for arg in forwarded if arg != "--scaffold"]

    if not has_flag(forwarded, "--mode"):
        mode = "scaffold" if scaffold else "autochecklist"
        forwarded = ["--mode", mode, *forwarded]

    defaults = [
        ("--backend", DEFAULT_BACKEND),
        ("--model", DEFAULT_MODEL),
        ("--provider", DEFAULT_PROVIDER),
        ("--base-url", DEFAULT_BASE_URL),
        ("--api-format", DEFAULT_API_FORMAT),
        ("--api-key-env", configured_api_key_env()),
        ("--scorer-mode", DEFAULT_SCORER_MODE),
    ]
    for flag, value in reversed(defaults):
        forwarded = add_default(forwarded, flag, value)
    return run_review_state.main(forwarded)


def parse(argv: list[str]) -> int:
    return parse_dp16276_checklist.main(argv)


def request_json(
    url: str,
    key: str,
    *,
    payload: dict[str, Any] | None = None,
    timeout: int = 60,
) -> tuple[int, dict[str, Any] | None, str]:
    data = None if payload is None else json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        method="GET" if data is None else "POST",
        headers={
            "Authorization": f"Bearer {key}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            return resp.status, json.loads(body), body
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        try:
            parsed = json.loads(body)
        except json.JSONDecodeError:
            parsed = None
        return exc.code, parsed, body
    except Exception as exc:  # noqa: BLE001 - doctor reports operational failures.
        return 0, None, f"{type(exc).__name__}: {exc}"


def error_message(parsed: dict[str, Any] | None, body: str) -> str:
    if isinstance(parsed, dict):
        error = parsed.get("error", parsed)
        if isinstance(error, dict) and error.get("message"):
            return str(error["message"])
        if parsed.get("message"):
            return str(parsed["message"])
    return body.strip()


def autochecklist_version(executable: str) -> str:
    proc = subprocess.run(
        [executable, "--version"],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
        timeout=15,
    )
    text = (proc.stdout or proc.stderr).strip()
    return text or f"exit {proc.returncode}"


def autochecklist_fable_smoke(args: argparse.Namespace) -> dict[str, Any]:
    with tempfile.TemporaryDirectory(prefix="ai4ss-manuscript-reviewer-doctor-") as tmp:
        tmp_path = Path(tmp)
        manuscript_path = tmp_path / "smoke.md"
        outdir = tmp_path / "review"
        manuscript_path.write_text(
            "# Clear Title About a Research Question\n\n"
            "This smoke manuscript has a visible title for a checklist test.\n",
            encoding="utf-8",
        )
        forwarded = [
            "--manuscript",
            str(manuscript_path),
            "--outdir",
            str(outdir),
            "--mode",
            "autochecklist",
            "--backend",
            "cli",
            "--suites",
            "TITLE",
            "--max-items",
            "1",
            "--model",
            args.model,
            "--provider",
            DEFAULT_PROVIDER,
            "--base-url",
            args.base_url,
            "--api-format",
            DEFAULT_API_FORMAT,
            "--api-key-env",
            args.api_key_env,
            "--scorer-mode",
            DEFAULT_SCORER_MODE,
            "--cli-timeout",
            str(args.timeout),
        ]
        stdout = io.StringIO()
        stderr = io.StringIO()
        with contextlib.redirect_stdout(stdout), contextlib.redirect_stderr(stderr):
            exit_code = run_review_state.main(forwarded)
        if exit_code != 0:
            return {
                "ok": False,
                "exit_code": exit_code,
                "stdout": stdout.getvalue()[-500:],
                "stderr": stderr.getvalue()[-500:],
            }
        state = json.loads((outdir / "review_state.json").read_text(encoding="utf-8"))
        return {
            "ok": (
                state["manifest"]["config"]["backend"] == "cli"
                and state["manifest"]["config"]["model"] == args.model
                and state["manifest"]["config"]["cli_packyapi_shim"] is True
                and state["scorer_metadata"]["scoring_method"] == "cli:item"
                and state["scorer_metadata"]["cli_adapter"] == "packyapi_fable_shim"
            ),
            "review_id": state["review_id"],
            "backend": state["manifest"]["config"]["backend"],
            "model": state["manifest"]["config"]["model"],
            "scoring_method": state["scorer_metadata"]["scoring_method"],
            "cli_adapter": state["scorer_metadata"]["cli_adapter"],
            "counts": state["summary"]["counts_by_status"],
        }


def doctor(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Check the manuscript-reviewer CLI and PackyAPI/Fable backend.")
    parser.add_argument("--model", default=DEFAULT_MODEL)
    parser.add_argument("--base-url", default=DEFAULT_BASE_URL)
    parser.add_argument("--api-key-env", default=configured_api_key_env())
    parser.add_argument("--timeout", type=int, default=60)
    parser.add_argument("--skip-probe", action="store_true", help="Skip the billable AutoChecklist CLI smoke probe.")
    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
    args = parser.parse_args(argv)

    checks: list[dict[str, Any]] = []

    executable = shutil.which("autochecklist")
    checks.append(
        {
            "name": "autochecklist_cli",
            "ok": bool(executable),
            "path": executable,
            "version": autochecklist_version(executable) if executable else None,
        }
    )
    checks.append(
        {
            "name": "default_checklist",
            "ok": DEFAULT_CHECKLIST_JSON.exists(),
            "path": str(DEFAULT_CHECKLIST_JSON),
        }
    )

    key = os.environ.get(args.api_key_env)
    checks.append(
        {
            "name": "api_key_env",
            "ok": bool(key),
            "env": args.api_key_env,
            "length": len(key) if key else 0,
        }
    )

    model_ids: list[str] = []
    if key:
        models_url = f"{args.base_url.rstrip('/')}/models"
        status, parsed, body = request_json(models_url, key, timeout=args.timeout)
        if isinstance(parsed, dict):
            model_ids = [
                str(item.get("id"))
                for item in parsed.get("data", [])
                if isinstance(item, dict) and item.get("id")
            ]
        checks.append(
            {
                "name": "packyapi_models",
                "ok": status == 200,
                "status": status,
                "base_url": args.base_url,
                "models_count": len(model_ids),
                "has_model": args.model in model_ids,
                "error": None if status == 200 else error_message(parsed, body)[:400],
            }
        )
    else:
        checks.append(
            {
                "name": "packyapi_models",
                "ok": False,
                "status": None,
                "base_url": args.base_url,
                "models_count": 0,
                "has_model": False,
                "error": f"{args.api_key_env} is not set",
            }
        )

    if key and not args.skip_probe:
        smoke = autochecklist_fable_smoke(args)
        checks.append(
            {
                "name": "autochecklist_cli_fable_smoke",
                **smoke,
            }
        )
    elif args.skip_probe:
        checks.append(
            {
                "name": "autochecklist_cli_fable_smoke",
                "ok": True,
                "skipped": True,
                "model": args.model,
            }
        )

    overall_ok = all(check.get("ok") for check in checks)
    result = {
        "ok": overall_ok,
        "default_model": args.model,
        "default_provider": DEFAULT_PROVIDER,
        "default_base_url": args.base_url,
        "default_api_format": DEFAULT_API_FORMAT,
        "default_scorer_mode": DEFAULT_SCORER_MODE,
        "checks": checks,
    }
    if args.json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        print(f"manuscript-reviewer doctor: {'OK' if overall_ok else 'NOT READY'}")
        for check in checks:
            status = "OK" if check.get("ok") else "FAIL"
            detail = check.get("version") or check.get("path") or check.get("error") or ""
            if check["name"] == "packyapi_models":
                detail = f"{check.get('models_count')} models, has {args.model}={check.get('has_model')}"
                if check.get("error"):
                    detail += f", error={check['error']}"
            if check["name"] == "autochecklist_cli_fable_smoke":
                detail = (
                    f"{check.get('scoring_method')} via {check.get('cli_adapter')} "
                    f"counts={check.get('counts')}"
                    if check.get("ok")
                    else check.get("stderr") or check.get("stdout") or check.get("error") or ""
                )
            print(f"- {status} {check['name']}: {detail}")
    return 0 if overall_ok else 2


def print_help() -> None:
    print(
        "\n".join(
            [
                "usage: manuscript-reviewer <command> [options]",
                "",
                "Commands:",
                "  review   Score a manuscript with the fixed DP16276 checklist",
                "  parse    Parse a DP16276 Markdown checklist to structured JSON",
                "  doctor   Check AutoChecklist and PackyAPI/Fable readiness",
                "",
                "Default scoring path:",
                "  scorer=autochecklist CLI",
                f"  scorer_mode={DEFAULT_SCORER_MODE}",
                f"  provider={DEFAULT_PROVIDER}",
                f"  api_format={DEFAULT_API_FORMAT}",
                f"  model={DEFAULT_MODEL}",
                f"  base_url={DEFAULT_BASE_URL}",
                f"  api_key_env={configured_api_key_env()}",
                "",
                "Examples:",
                "  manuscript-reviewer doctor",
                "  manuscript-reviewer review --manuscript draft.md --outdir review --suites TITLE --max-items 3",
                "  manuscript-reviewer parse ~/Downloads/dp16276-tdd-checklist.md -o checklist.json --expect-items 302",
            ]
        )
    )


def main(argv: list[str] | None = None) -> int:
    args = list(sys.argv[1:] if argv is None else argv)
    if not args or args[0] in {"-h", "--help"}:
        print_help()
        return 0

    command = args[0]
    rest = args[1:]
    if command == "review":
        return review(rest)
    if command == "parse":
        return parse(rest)
    if command == "doctor":
        return doctor(rest)
    if command.startswith("-"):
        return review(args)

    print(f"ERROR unknown command: {command}", file=sys.stderr)
    print_help()
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
