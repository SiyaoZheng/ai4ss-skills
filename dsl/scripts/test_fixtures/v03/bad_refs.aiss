aiss version "0.3"

paper bad.paper {
  title: "Bad References"
  kind: "article"
  sources: [bad.src_text]
}

source bad.src_text {
  kind: "article_text"
  uri: "sources/bad.txt"
  media_type: "text/plain"
  locator_scheme: "char"
}

span bad.s_one {
  source: bad.src_text
  locator: "char:1-10"
}

concept bad.concept_alpha {
  term: "alpha"
  spans: [bad.s_one]
}

claim bad.claim_alpha {
  kind: "theoretical"
  text: "Alpha matters."
  concepts: [bad.concept_missing]
  spans: [bad.s_missing]
}

empirical bad.emp_case {
  kind: "case"
  label: "case"
  spans: [bad.s_one]
}

coupling bad.coup_wrong_endpoints {
  type: "supports"
  theory: bad.emp_case
  empirical: bad.claim_alpha
  asserted_by: "paper"
  spans: [bad.s_one]
}
